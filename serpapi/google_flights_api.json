Code to integrate


Ruby

require "serpapi" 

client = SerpApi::Client.new(
  engine: "google_flights",
  currency: "USD",
  hl: "en",
  type: "3",
  multi_city_json: "[{"departure_id":"CDG","arrival_id":"NRT","date":"2026-04-10"},{"departure_id":"NRT","arrival_id":"LAX,SEA","date":"2026-04-17"},{"departure_id":"LAX,SEA","arrival_id":"AUS","date":"2026-04-24","times":"8,18,9,23"}]",
  api_key: "697c05cd6b6463eba244ca9769758ae5a3d4bc0e6547fc72797084d3d01665d9"
)

results = client.search

