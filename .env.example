# VRTSPACE1 environment variables
# Copy this file to `.env` for local development, or configure equivalent
# environment variables in your production host (Render, Vercel, etc).
# Never commit a real `.env` file.

# ---------------------------------------------------------------------------
# Django core
# ---------------------------------------------------------------------------
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_ENV=dev

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Either DATABASE_URL (recommended on Render/Heroku) or the individual POSTGRES_* vars.
# Leave blank in dev to fall back to SQLite at db.sqlite3.
DATABASE_URL=

# ---------------------------------------------------------------------------
# Cache / Celery / Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379/0
AUDIT_USE_CELERY=0
AUDIT_BACKGROUND_WORKERS=2

# ---------------------------------------------------------------------------
# Stripe (subscriptions)
#
# 1. Create your products and recurring prices in the Stripe dashboard.
# 2. Copy the Price IDs (they start with `price_`) into the variables below.
#    The price amounts in Stripe MUST match the public pricing:
#       Starter   = $59 / month  -> STRIPE_PRICE_STARTER
#       Growth    = $149 / month -> STRIPE_PRICE_GROWTH
#       Authority = $349 / month -> STRIPE_PRICE_AUTHORITY
#       Enterprise= custom       -> STRIPE_PRICE_ENTERPRISE (optional)
# 3. After deploying, run `python manage.py shell -c "from apps.leads.billing import sync_workspace_plan_catalog; sync_workspace_plan_catalog()"`
#    so the Price IDs are mirrored onto each WorkspacePlan row in the database.
# ---------------------------------------------------------------------------
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_AUTHORITY=
STRIPE_PRICE_ENTERPRISE=

# ---------------------------------------------------------------------------
# Google OAuth (workspace login)
# ---------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# SerpAPI (SEO + AEO intelligence)
# ---------------------------------------------------------------------------
SERPAPI_API_KEY=
SERP_DISCOVERY_PROVIDER=serpapi,duckduckgo

# ---------------------------------------------------------------------------
# Google PageSpeed Insights (audit performance scoring)
# ---------------------------------------------------------------------------
PAGESPEED_API_KEY=

# ---------------------------------------------------------------------------
# Email (audit reports, credit alerts, influencer statements)
# ---------------------------------------------------------------------------
EMAIL_HOST=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_PORT=587
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=no-reply@vrtspace.example
