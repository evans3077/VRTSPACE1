# =============================================================================
# VRT SPACE AGENCY — Environment Variables
# =============================================================================
# Copy this file to `.env` for local development, or configure equivalent
# environment variables in your production host (Render, Fly, Heroku, Vercel).
#
# NEVER commit a real `.env` file. The `.env*.local` variants are gitignored
# for personal overrides that should never leave your machine.
#
# Reference layout:
#   1.  Django core
#   2.  Database
#   3.  Cache / queue (Redis + Celery)
#   4.  Hosting auto-detected vars (Render / Vercel — leave empty locally)
#   5.  Stripe (subscriptions + credit top-ups)
#   6.  Google OAuth (workspace sign-in)
#   7.  LLM engines (P1 AEO precision layer + P5 public AEO index)
#   8.  SERP / search-data providers (SEO discovery + AEO intelligence)
#   9.  PageSpeed / DataForSEO (audit performance + market data)
#   10. Email (SMTP for invites, credit alerts, audit reports)
#   11. Sentry (error tracking)
#   12. Tuning knobs (audit workers, SERP rate limits, share expiry, etc.)
#   13. Affiliate program
# =============================================================================


# -----------------------------------------------------------------------------
# 1. Django core
# -----------------------------------------------------------------------------
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=1                                # 0 in production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_ENV=dev                                # dev | staging | production
DJANGO_SECURE_SSL_REDIRECT=0                  # 1 in production (Render auto-injects HTTPS)
APP_BASE_URL=                                 # e.g. https://vrtspaceagency.onrender.com (used in emails + share links)


# -----------------------------------------------------------------------------
# 2. Database
# -----------------------------------------------------------------------------
# Option A — DATABASE_URL (recommended on Render/Heroku):
DATABASE_URL=
# Option B — explicit Postgres credentials (Docker / self-hosted):
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=5432
# Option C — leave both empty in dev to fall back to SQLite at db.sqlite3.


# -----------------------------------------------------------------------------
# 3. Cache / queue
# -----------------------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=                            # falls back to REDIS_URL
CELERY_RESULT_BACKEND=                        # falls back to REDIS_URL
AUDIT_USE_CELERY=0                            # 1 to dispatch audits through Celery; 0 uses the in-process ThreadPoolExecutor
AUDIT_BACKGROUND_WORKERS=2                    # ThreadPoolExecutor size for audit + post-audit jobs
SEO_BACKGROUND_WORKERS=2                      # ThreadPoolExecutor size for SEO snapshots
SEO_REFRESH_ASYNC=1                           # 1 = SEO refresh runs off-thread
SEO_BACKLINK_ASYNC=1                          # 1 = backlink prospecting runs off-thread


# -----------------------------------------------------------------------------
# 4. Hosting auto-detected (DO NOT SET LOCALLY)
# -----------------------------------------------------------------------------
# Render and Vercel inject these at runtime. Listed here for reference only.
# RENDER=true
# RENDER_EXTERNAL_HOSTNAME=
# RENDER_INSTANCE_ID=
# RENDER_SERVICE_ID=
# VERCEL=1
# VERCEL_ENV=
# VERCEL_URL=


# -----------------------------------------------------------------------------
# 5. Stripe — subscriptions + credit top-ups
# -----------------------------------------------------------------------------
# Set-up steps:
#   1. In the Stripe dashboard, create your products + RECURRING prices for
#      Starter/Growth/Authority. Amounts must match public pricing:
#          Starter   = $59 / month
#          Growth    = $149 / month
#          Authority = $349 / month
#          Enterprise= custom (optional)
#   2. Copy the Price IDs (start with `price_`) into the variables below.
#   3. Create one-time (mode=payment) prices for the three credit top-up packs
#      at $10 / $25 / $50.
#   4. After deploying, run:
#          python manage.py shell -c "from apps.leads.billing import sync_workspace_plan_catalog; sync_workspace_plan_catalog()"
#      so the Price IDs are mirrored onto each WorkspacePlan row.
#   5. Configure the webhook endpoint at /billing/stripe/webhook/ and copy the
#      signing secret to STRIPE_WEBHOOK_SECRET.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_AUTHORITY=
STRIPE_PRICE_ENTERPRISE=
STRIPE_PRICE_TOPUP_10=
STRIPE_PRICE_TOPUP_30=
STRIPE_PRICE_TOPUP_70=


# -----------------------------------------------------------------------------
# 6. Google OAuth — workspace sign-in
# -----------------------------------------------------------------------------
# Get these from Google Cloud Console -> APIs & Services -> Credentials.
# Authorized redirect URI must be:  <APP_BASE_URL>/auth/google/callback/
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# 7. LLM engines — P1 AEO precision + P5 public AEO index
# -----------------------------------------------------------------------------
# The AEO workspace + the public /aeo-index/ tool send real queries to these
# engines. When a key is missing, that engine is silently skipped and the
# workspace banner says so. To enable real citation tracking, set all three.

# OpenAI (ChatGPT). Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini. Get from https://aistudio.google.com/app/apikey
# Either name works; precision.py reads both.
GEMINI_API_KEY=
GOOGLE_AI_API_KEY=

# Perplexity (Sonar). Get from https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# Google Cloud Natural Language API (entity-confidence scoring in geo_api.py).
# Optional — only needed for the GEO Shootout feature.
GOOGLE_CLOUD_API_KEY=


# -----------------------------------------------------------------------------
# 8. SERP / search-data providers
# -----------------------------------------------------------------------------
# SerpApi powers competitor discovery, AI-overview parsing, related-questions,
# and local-pack data. Get a key at https://serpapi.com (free tier = 100/mo).
SERPAPI_API_KEY=

# Discovery provider priority order (comma-separated). Recognised: serpapi, duckduckgo.
SERP_DISCOVERY_PROVIDER=serpapi,duckduckgo


# -----------------------------------------------------------------------------
# 9. PageSpeed / DataForSEO
# -----------------------------------------------------------------------------
# Google PageSpeed Insights — audit performance scoring.
# Get from https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# DataForSEO — enterprise search-volume + domain authority (optional, used by
# Clinical Market Data feature). Get at https://dataforseo.com/.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=


# -----------------------------------------------------------------------------
# 10. Email — SMTP for invites, credit alerts, audit reports
# -----------------------------------------------------------------------------
# settings.py auto-switches to the SMTP backend when EMAIL_HOST is set; leave
# blank locally to use the console backend (prints messages to the dev log).
#
# Recommended providers + their settings:
#   SendGrid:    EMAIL_HOST=smtp.sendgrid.net   EMAIL_HOST_USER=apikey   EMAIL_HOST_PASSWORD=<SG.xxx>
#   Resend:      EMAIL_HOST=smtp.resend.com     EMAIL_HOST_USER=resend   EMAIL_HOST_PASSWORD=<re_xxx>
#   Mailgun:     EMAIL_HOST=smtp.mailgun.org    EMAIL_HOST_USER=<smtp_user>   EMAIL_HOST_PASSWORD=<smtp_pass>
EMAIL_HOST=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=no-reply@vrtspace.example
SERVER_EMAIL=no-reply@vrtspace.example
# Optional explicit override; only set if you need to override the auto-selection.
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend


# -----------------------------------------------------------------------------
# 11. Sentry — error tracking
# -----------------------------------------------------------------------------
# Initialised only when SENTRY_DSN is set, so local dev is a no-op.
# Sign up at https://sentry.io, create a Django project, copy the DSN.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1                 # 0.0 - 1.0; sampled performance traces


# -----------------------------------------------------------------------------
# 12. Tuning knobs (optional)
# -----------------------------------------------------------------------------
AUDIT_TIER_ENFORCEMENT=1                      # 1 = real billing gates; 0 = shadow mode (testing)
CONTENT_REFINEMENT_TIMEOUT=60                 # seconds for content-generation requests
DEFAULT_AUDIT_SHARE_EXPIRY_DAYS=30            # public audit share-link lifetime

# SERP discovery rate limits (per onboarding session / per audit)
SEO_COMPETITOR_LIMIT=4
SEO_COMPETITOR_PAGE_LIMIT=8
SERP_DISCOVERY_QUERY_LIMIT=12
SERP_DISCOVERY_RESULTS_PER_QUERY=10
SERP_PROVIDER_TIMEOUT_SECONDS=20
SERP_PROVIDER_COOLDOWN_SECONDS=60
SERP_DUCKDUCKGO_TIMEOUT_SECONDS=15
SERP_DUCKDUCKGO_COOLDOWN_SECONDS=120


# -----------------------------------------------------------------------------
# 13. Affiliate program
# -----------------------------------------------------------------------------
AFFILIATE_STRIPE_CONNECT_ENABLED=0
AFFILIATE_COMMISSION_FIRST_PAYMENT_PCT=25     # 25% on first payment
AFFILIATE_COMMISSION_RECURRING_PCT=10         # 10% on recurring
AFFILIATE_COOKIE_MAX_AGE_DAYS=30
AFFILIATE_PAYOUT_HOLD_DAYS=14
